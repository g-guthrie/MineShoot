{
  "name": "mayhem-pvp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Highchair PvP shooter runtime for Mayhem Arena",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "bash scripts/dev-games.sh",
    "dev:pvp": "bash scripts/dev-games.sh",
    "typecheck": "npm --prefix highchair-game run typecheck",
    "build": "npm --prefix highchair-game run build && npm --prefix highchair-client run build",
    "build:game": "npm --prefix highchair-game run build",
    "build:client": "npm --prefix highchair-client run build"
  }
}
