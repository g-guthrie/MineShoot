#!/usr/bin/env bash
# Local dev fallback for the SDK's KTX atlas generation.
# If a cached atlas already exists, keep it and report success. Install the
# real KTX toktx binary before changing block textures or regenerating atlases.
set -euo pipefail

if [ "$#" -lt 2 ]; then
  echo "local toktx shim: expected output and input paths" >&2
  exit 2
fi

prev=
last=
for arg in "$@"; do
  prev="$last"
  last="$arg"
done

output="$prev"
input="$last"

if [ -f "$output" ]; then
  touch "$output"
  echo "local toktx shim: kept cached $output from $input" >&2
  exit 0
fi

# No cached KTX2: report success WITHOUT producing one. The engine keeps the
# freshly generated atlas.json + atlas.png pair, the client's KTX2 fetch 404s,
# and its built-in PNG-atlas fallback kicks in — which is always consistent
# with the fresh metadata. (A stale cached KTX2 next to fresh metadata is how
# every block face ended up rendering as a flat average color.)
echo "local toktx shim: no cached $output — engine will serve the PNG atlas only" >&2
exit 0
