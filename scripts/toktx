#!/usr/bin/env bash
# Delegates to the real KTX-Software toktx when installed; otherwise keeps a
# cached atlas (legacy dev fallback from before KTX-Software was available).
set -euo pipefail

for real in /opt/homebrew/bin/toktx /usr/local/bin/toktx; do
  if [ -x "$real" ]; then
    exec "$real" "$@"
  fi
done

prev=
last=
for arg in "$@"; do
  prev="$last"
  last="$arg"
done
output="$prev"

if [ -f "$output" ]; then
  touch "$output"
  echo "local toktx shim: kept cached $output" >&2
  exit 0
fi
echo "local toktx shim: no cached $output — engine will serve the PNG atlas only" >&2
exit 0
